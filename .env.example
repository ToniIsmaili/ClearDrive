# Expected license plate format (X = any letter, 0 = digit, F = prefix from OCR_PLATE_PREFIX_VALUES)
OCR_PLATE_FORMAT=FF 0000 XX

# Allowed prefix values for F segments (comma-separated)
OCR_PLATE_PREFIX_VALUES=SK,KU,ST,TE,VE

# Black-character isolation thresholds (HSV: saturation and value caps)
OCR_BLACK_V_MAX=80
OCR_BLACK_S_MAX=100

# Minimum crop height before OCR (image is upscaled if smaller)
OCR_MIN_PLATE_HEIGHT=50

# Tesseract page segmentation mode (7 = single text line)
OCR_TESSERACT_PSM=7

# Path to tesseract executable (required on Windows if not on PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
