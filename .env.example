# Raspberry Pi GPIO (install via apt before pip install -r requirements.txt):
#   sudo apt update
#   sudo apt install -y swig liblgpio-dev python3-lgpio
#
# Expected license plate format (X = any letter, 0 = digit, F = prefix from OCR_PLATE_PREFIX_VALUES)
OCR_PLATE_FORMAT=FF 0000 XX

# Allowed prefix values for F segments (comma-separated)
OCR_PLATE_PREFIX_VALUES=SK,KU,ST,TE,VE

# Black-character isolation (LAB: max ink lightness and max deviation from neutral gray)
OCR_BLACK_V_MAX=110
OCR_BLACK_S_MAX=35

# Minimum crop height before OCR (image is upscaled if smaller)
OCR_MIN_PLATE_HEIGHT=50

# Tesseract page segmentation mode (7 = single text line)
OCR_TESSERACT_PSM=7

# Path to tesseract executable (required on Windows if not on PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# InfluxDB Cloud whitelist (token is required; org/bucket are auto-discovered)
INFLUX_URL=https://your-region.aws.cloud2.influxdata.com
INFLUX_TOKEN=your-influx-cloud-api-token
# INFLUX_ORG=your-org-name
INFLUX_BUCKET=Whitelist

# InfluxDB whitelist query settings (measurement/field or custom Flux query)
INFLUX_WHITELIST_MEASUREMENT=whitelist
INFLUX_WHITELIST_FIELD=plate
# INFLUX_WHITELIST_QUERY=from(bucket: "cleardrive") |> range(start: -90d) |> ...

# Local in-memory cache TTL in seconds (default: 5 minutes)
WHITELIST_CACHE_TTL_SECONDS=300

# Run without OpenCV preview windows (auto-enabled when DISPLAY is unset)
# CLEARDRIVE_HEADLESS=true

# SG90 servo ramp control (Raspberry Pi GPIO; set SERVO_ENABLED=false on dev machines)
SERVO_ENABLED=true
SERVO_GPIO_PIN=18
SERVO_OPEN_ANGLE=90
SERVO_CLOSE_ANGLE=0
SERVO_CLOSE_DELAY_SECONDS=5

# AWS SNS event publishing (triggered only for whitelisted plates)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:cleardrive-events
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_SESSION_TOKEN=your-temporary-session-token
